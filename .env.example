# GUYA FIBRE Frontend - Environment Variables Template
# Copy this file to .env.local and fill in your values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_TIMEOUT=10000

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=

# Third-party services
NEXT_PUBLIC_WHATSAPP_NUMBER=594694435484
NEXT_PUBLIC_CONTACT_EMAIL=contact@guyafibre.com
NEXT_PUBLIC_CONTACT_PHONE=0694435484

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_FORM_API=true

# Site configuration
NEXT_PUBLIC_SITE_URL=https://guyafibre.com
NEXT_PUBLIC_ENVIRONMENT=production
